<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Travel &amp; Expense — City of North Platte</title>
  <link rel="stylesheet" href="/css/style.css">
  <% if (embedded) { %>
  <style>
    .app-header { padding: 8px 16px; }
    .app-header h1 { font-size: 14px; }
    .container { padding: 16px 14px 40px; }
    body { background: #fff; }
    .card { box-shadow: var(--shadow-sm); }
  </style>
  <% } %>
</head>
<body>

<!-- ══════ HEADER ══════ -->
<header class="app-header">
  <div style="display:flex;align-items:center;gap:14px">
    <img src="/images/2022_CityLogo_WHITEFG.png" alt="City Seal" style="height:44px;width:44px">
    <div>
      <h1 style="margin:0;font-size:18px;letter-spacing:0.5px">City of North Platte</h1>
      <span class="subtitle" style="font-size:11px;opacity:0.75;letter-spacing:1px;text-transform:uppercase">Travel &amp; Expense Form</span>
    </div>
  </div>
  <div class="header-right">
    <% if (user) { %>
      <div class="user-badge"><span class="dot"></span> <%= user.name %></div>
      <a href="/auth/signout" class="btn btn-sm" style="color:#fff;text-decoration:none;opacity:0.8">Sign Out</a>
    <% } else { %>
      <% if (embedded) { %>
        <button class="btn btn-sm" style="background:rgba(255,255,255,0.15);color:#fff" onclick="popupSignIn()">Sign In</button>
      <% } else { %>
        <a href="/auth/signin" class="btn btn-sm" style="background:rgba(255,255,255,0.15);color:#fff;text-decoration:none">Sign In</a>
      <% } %>
    <% } %>
  </div>
</header>

<div class="container">

  <!-- ══════ SHAREPOINT PICKER ══════ -->
  <div class="card sp-card">
    <div class="card-header" onclick="toggleSP()">
      <div style="display:flex;align-items:center;gap:8px">
        <span>📋</span> SharePoint — Travel Expense Requests
        <% if (user) { %><span style="font-size:11px;background:rgba(255,255,255,0.2);padding:2px 10px;border-radius:12px;margin-left:8px">● Connected</span><% } %>
      </div>
      <span class="chevron" id="spChevron">▾</span>
    </div>
    <div class="card-body open" id="spBody">
      <% if (!user) { %>
        <p style="color:var(--gray-500);margin-bottom:12px">Sign in with your City account to load travel requests from SharePoint.</p>
        <% if (embedded) { %>
          <button class="btn btn-primary" onclick="popupSignIn()">🔑 Sign In with Microsoft</button>
        <% } else { %>
          <a href="/auth/signin" class="btn btn-primary" style="text-decoration:none">🔑 Sign In with Microsoft</a>
        <% } %>
      <% } else if (spError) { %>
        <div class="toast toast-error"><%= spError %></div>
      <% } else { %>
        <label style="font-size:11px;font-weight:600;color:var(--gray-500);text-transform:uppercase">
          Select a Request (<%= items.length %> items)
        </label>
        <select class="sp-select" id="spItemSelect" onchange="pullIntoForm()">
          <option value="">— Select a request —</option>
          <% items.forEach((item) => { %>
            <option value="<%= item.id %>">
              <%= item.fields.Title || '' %><%= item.requesterName ? ' | ' + item.requesterName : '' %><%= item.fields.TravelStartDate ? ' | ' + new Date(item.fields.TravelStartDate).toLocaleDateString() : '' %>
            </option>
          <% }); %>
        </select>

        <div class="sp-preview" id="spPreview"></div>
        <div id="spStatus"></div>
      <% } %>
    </div>
  </div>

  <!-- ══════ REQUEST SECTION ══════ -->
  <div class="card">
    <div class="card-header">
      <span>Travel Request</span>
      <div class="action-bar no-print" style="margin:0">
        <a href="/forms/reconcile" class="btn btn-sm" style="background:var(--accent);color:#fff;text-decoration:none">Post-Trip Reconciliation →</a>
        <button class="btn btn-success btn-sm" onclick="generatePDF()">📄 Generate PDF</button>
        <button class="btn btn-outline btn-sm" onclick="clearForm()">Clear</button>
      </div>
    </div>
    <div class="card-body">
      <div id="pdfStatus"></div>

      <!-- ── Compliance Statement (top) ── -->
      <div style="margin-bottom:24px;padding:16px 20px;background:#f9fafb;border:1px solid var(--gray-200);border-radius:8px;line-height:1.7;font-size:14px">
        <p style="margin:0">
          In compliance with the City of North Platte, NE, policy manual, I hereby request
          Educational, Training, or other City Business leave as requested below:
        </p>
      </div>

      <div class="form-grid">
        <div class="form-group full">
          <label>Department</label>
          <input id="department" data-field type="text">
        </div>
        <div class="form-group full">
          <label>Employee Name</label>
          <input id="employeeName" data-field type="text">
        </div>
        <div class="form-group">
          <label>From Time</label>
          <input id="fromTime" data-field type="text" placeholder="8:00 AM">
        </div>
        <div class="form-group">
          <label>From Date</label>
          <input id="fromDate" data-field type="text">
        </div>
        <div class="form-group">
          <label>To Time</label>
          <input id="toTime" data-field type="text" placeholder="5:00 PM">
        </div>
        <div class="form-group">
          <label>To Date</label>
          <input id="toDate" data-field type="text">
        </div>
        <div class="form-group full">
          <label>Purpose of Travel</label>
          <input id="purpose" data-field type="text">
        </div>
        <div class="form-group full">
          <label>Purpose (continued)</label>
          <input id="purpose2" data-field type="text">
        </div>
        <div class="form-group full">
          <label>Location</label>
          <input id="location" data-field type="text">
        </div>
      </div>

      <!-- ── Estimated Education/Training Expenses ── -->
      <div class="cost-section" style="margin-top:20px">
        <div style="font-size:12px;font-weight:600;color:var(--gray-500);text-transform:uppercase;margin-bottom:10px">
          Estimated Education/Training Expenses
        </div>

        <div class="cost-row">
          <div class="row-label">Registration</div>
          <div></div><div></div>
          <input id="regCheck" data-field type="text" class="total-field" placeholder="0.00">
        </div>
        <div class="cost-row">
          <div class="row-label">Commercial Travel</div>
          <div></div><div></div>
          <input id="travelCheck" data-field type="text" class="total-field" placeholder="0.00">
        </div>
        <div class="cost-row">
          <div class="row-label">Lodging</div>
          <input id="lodgingNights" data-field type="text" placeholder="# nights">
          <input id="lodgingRate" data-field type="text" placeholder="rate/night">
          <input id="lodgingTotal" data-field type="text" class="total-field" placeholder="0.00" readonly>
        </div>
        <div class="cost-row">
          <div class="row-label">Mileage</div>
          <input id="mileageMiles" data-field type="text" placeholder="# miles">
          <input id="mileageRate" data-field type="text" placeholder="rate/mile">
          <input id="mileageTotal" data-field type="text" class="total-field" placeholder="0.00" readonly>
        </div>

        <!-- Meals header -->
        <div style="font-size:12px;font-weight:600;color:var(--gray-500);text-transform:uppercase;margin:16px 0 6px">
          Meals
        </div>
        <div class="meal-header">
          <div></div>
          <div style="text-align:center">In State</div>
          <div style="text-align:center">Out of State</div>
          <div style="text-align:right">Total</div>
        </div>
        <div class="meal-row">
          <div class="row-label">Breakfast</div>
          <input id="breakfastIS" data-field type="text" placeholder="#">
          <input id="breakfastISRate" data-field type="text" placeholder="rate">
          <input id="breakfastOS" data-field type="text" placeholder="#">
          <input id="breakfastOSRate" data-field type="text" placeholder="rate">
          <input id="breakfastTotal" data-field type="text" class="total-field" placeholder="0.00" readonly>
        </div>
        <div class="meal-row">
          <div class="row-label">Lunch</div>
          <input id="lunchIS" data-field type="text" placeholder="#">
          <input id="lunchISRate" data-field type="text" placeholder="rate">
          <input id="lunchOS" data-field type="text" placeholder="#">
          <input id="lunchOSRate" data-field type="text" placeholder="rate">
          <input id="lunchTotal" data-field type="text" class="total-field" placeholder="0.00" readonly>
        </div>
        <div class="meal-row">
          <div class="row-label">Supper</div>
          <input id="supperIS" data-field type="text" placeholder="#">
          <input id="supperISRate" data-field type="text" placeholder="rate">
          <input id="supperOS" data-field type="text" placeholder="#">
          <input id="supperOSRate" data-field type="text" placeholder="rate">
          <input id="supperTotal" data-field type="text" class="total-field" placeholder="0.00" readonly>
        </div>

        <div class="cost-row">
          <div class="row-label">Other</div>
          <input id="other1Desc" data-field type="text" placeholder="Description" style="grid-column:2/4">
          <input id="other1Total" data-field type="text" class="total-field" placeholder="0.00">
        </div>
        <div class="cost-row">
          <div class="row-label"></div>
          <input id="other2Desc" data-field type="text" placeholder="Description" style="grid-column:2/4">
          <input id="other2Total" data-field type="text" class="total-field" placeholder="0.00">
        </div>

        <div class="total-bar">
          <label>Estimated Trip Total</label>
          <span style="font-size:18px;font-weight:700;color:var(--brand)">$</span>
          <input id="estimatedTotal" data-field type="text" readonly>
        </div>


      </div>

      <!-- ── Advance Statement ── -->
      <div style="margin-top:20px;padding:14px 18px;background:var(--brand-light);border:2px solid var(--brand);border-radius:8px;line-height:1.8;font-size:14px">
        I further request advance travel expense money of
        <span style="font-weight:700;color:var(--brand)">$</span>
        <input id="advanceMoney" data-field type="text" placeholder="0.00" style="width:120px;display:inline-block;font-size:14px;font-weight:600;border:2px solid var(--brand);border-radius:4px;padding:4px 8px;text-align:center;vertical-align:middle">
        and will upon my return, submit an itemized statement of actual expenses incurred in the space below.
      </div>

      <!-- ── Signatures ── -->
      <div class="sig-grid">
        <div class="sig-block">
          <label>Employee Signature</label>
          <input type="text" disabled placeholder="(signature)">
        </div>
        <div class="sig-block">
          <label>Department Head</label>
          <input id="deptHead" data-field type="text">
        </div>
        <div class="sig-block">
          <label>City Administrator</label>
          <input id="cityAdmin" data-field type="text">
        </div>
        <div class="sig-block">
          <label>Date</label>
          <input id="approvalDate" data-field type="text">
        </div>
      </div>
    </div>
  </div>

</div>

<script src="/js/form.js"></script>
<% if (embedded) { %>
<script>
  function popupSignIn() {
    const w = 500, h = 650;
    const left = (screen.width - w) / 2;
    const top = (screen.height - h) / 2;
    window.open(
      "/auth/signin?embedded=1",
      "CityFormsAuth",
      "width=" + w + ",height=" + h + ",top=" + top + ",left=" + left + ",toolbar=no,menubar=no"
    );
  }
  window.addEventListener("message", (e) => {
    if (e.data && e.data.type === "auth-complete") {
      location.reload();
    }
  });
</script>
<% } %>
</body>
</html>
